class Solution {
    public boolean searchMatrix(int[][] matrix, int target) {

        

        int rows = matrix.length; 

        int columns = matrix[0].length; 

        if(rows == 1 && columns == 1 && target == matrix[0][0]){
            return true;
        }

       
        for(int i = 0; i < rows; i++){
            for(int j = 0; j < columns; j++){
                if(target == matrix[i][j])
                return true;
            }
        }
        
        return false;
    }
}
