class Solution {
    public int findGCD(int[] nums) {
        int max = nums[0], min = nums[0];

        for(int i = 0; i < nums.length; i++){
            if(max < nums[i]){
                max = nums[i];
            }

            if(min > nums[i]){
                min = nums[i];
            }

        }

        while (max != 0) {
            int temp = max;
            max = min % max;
            min = temp;
        }
        return min;
    }
        
    }
