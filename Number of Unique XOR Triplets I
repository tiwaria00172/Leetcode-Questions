class Solution {
    public int uniqueXorTriplets(int[] nums) {
        int n = nums.length;
        
        // Base case: if n is 1 or 2, the unique XOR results match n
        if (n <= 2) {
            return n;
        }
        
        // Find the smallest power of 2 strictly greater than n
        int ans = 1;
        while (ans <= n) {
            ans <<= 1;
        }
        return ans;
    }
}
