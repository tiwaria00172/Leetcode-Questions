import java.util.Arrays;

public class Solution {
    public int sumOfGcd(int[] nums) {
        int n = nums.length;
        int[] prefixGcd = new int[n];
        
        // Track the running maximum element
        int maxSoFar = nums[0];
        
        // Step 1: Construct the prefixGcd array
        for (int i = 0; i < n; i++) {
            maxSoFar = Math.max(maxSoFar, nums[i]);
            prefixGcd[i] = gcd(nums[i], maxSoFar);
        }
        
        // Step 2: Sort the prefixGcd array in non-decreasing order
        Arrays.sort(prefixGcd);
        
        // Step 3: Use two pointers to pair smallest and largest elements
        int totalSum = 0;
        int left = 0;
        int right = n - 1;
        
        while (left < right) {
            totalSum += gcd(prefixGcd[left], prefixGcd[right]);
            left++;
            right--;
        }
        
        return totalSum;
    }
    
    // Helper method to find the greatest common divisor (GCD)
    private int gcd(int a, int b) {
        while (b != 0) {
            int temp = b;
            b = a % b;
            a = temp;
        }
        return a;
    }
}
